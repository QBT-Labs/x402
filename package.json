{
  "name": "@qbtlabs/x402",
  "version": "0.2.3",
  "description": "Multi-chain payment protocol for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chains/evm": {
      "types": "./dist/chains/evm.d.ts",
      "import": "./dist/chains/evm.js"
    },
    "./chains/solana": {
      "types": "./dist/chains/solana.d.ts",
      "import": "./dist/chains/solana.js"
    },
    "./middleware/mcp": {
      "types": "./dist/middleware/mcp.d.ts",
      "import": "./dist/middleware/mcp.js"
    },
    "./proxy": {
      "types": "./dist/proxy/index.d.ts",
      "import": "./dist/proxy/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    }
  },
  "bin": {
    "qbtlabs-x402": "./dist/scripts/client-proxy.js",
    "x402-proxy": "./dist/scripts/client-proxy.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "x402",
    "payments",
    "mcp",
    "ai-agents",
    "crypto",
    "usdc"
  ],
  "author": "QBT Labs <hello@qbtlabs.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QBT-Labs/x402.git"
  },
  "homepage": "https://github.com/QBT-Labs/x402#readme",
  "bugs": {
    "url": "https://github.com/QBT-Labs/x402/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "viem": "^2.47.4",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
